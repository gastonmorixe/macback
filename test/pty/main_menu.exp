#!/usr/bin/env expect -f
set root [lindex $argv 0]
set timeout 10

set env(MACBACK_TEST_TTY_STDIO) "1"
spawn bash -lc "cd \"$root\" && ./macback"
expect -re {macback}
expect -re {Backup +Create a new backup run}
send -- "\033\[B"
expect -re {Restore +Restore from an existing backup}
send -- "\033\[A"
expect -re {Backup +Create a new backup run}
send -- "q"
expect eof
