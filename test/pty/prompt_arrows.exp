#!/usr/bin/env expect -f
set root [lindex $argv 0]
set timeout 10

spawn bash -lc "cd \"$root\" && stty -echo && trap 'stty echo' EXIT && source ./macback && prompt \"Custom destination path\" && ui_read_prompt_line && printf \"%s\\n\" \"\$REPLY\""
expect -re {Custom destination path}
send -- "\033\[A\033\[B/tmp/custom-pty-test\r"
expect {
  -re {\^\[\[A|\^\[\[B} { exit 1 }
  -re {/tmp/custom-pty-test} {}
}
expect eof
