#!/usr/bin/env expect -f
set root [lindex $argv 0]
set timeout 10

set env(MACBACK_TEST_DESTINATIONS) "/Volumes/ST1000LM1TB"
set env(MACBACK_TEST_TTY_STDIO) "1"
spawn bash -lc "cd \"$root\" && source ./macback && select_destination_base"
expect -re {Backup destination}
expect -re {Custom path}
send -- "j"
send -- "\r"
expect -re {Custom destination path}
send -- "\033\[A\033\[B/tmp/custom-pty-test\r"
expect {
  -re {\^\[\[A|\^\[\[B} { exit 1 }
  -re {/tmp/custom-pty-test} {}
}
expect eof
